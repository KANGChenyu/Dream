# ===== 应用配置 =====
APP_NAME=DreamLog
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_V1_PREFIX=/api/v1

# ===== 数据库 =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dreamlog
POSTGRES_PASSWORD=dreamlog123
POSTGRES_DB=dreamlog

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ===== JWT =====
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== AI 服务 =====
# 解读服务: claude / openai / deepseek
AI_INTERPRETER_PROVIDER=deepseek
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 绘图服务: dalle / stable_diffusion
AI_IMAGE_PROVIDER=dalle
DALLE_API_KEY=your-dalle-api-key

SD_API_URL=http://localhost:7860
SD_MODEL=dreamshaper_8

# ===== 对象存储 (OSS) =====
OSS_PROVIDER=aliyun
OSS_ACCESS_KEY=your-oss-access-key
OSS_SECRET_KEY=your-oss-secret-key
OSS_BUCKET=dreamlog
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_CDN_DOMAIN=https://cdn.dreamlog.app

# ===== 微信小程序 =====
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# ===== 短信服务 =====
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=your-sms-access-key
SMS_SECRET_KEY=your-sms-secret-key
SMS_SIGN_NAME=DreamLog
SMS_TEMPLATE_CODE=SMS_123456
